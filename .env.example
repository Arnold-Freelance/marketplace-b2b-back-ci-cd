# Application
APP_NAME=MarketPlace B2B
ENVIRONMENT=development

# Database (obligatoire)
# Local   : postgresql://USER:PASSWORD@localhost:5432/market_place_db
# Supabase : récupérer la chaîne "Session pooler" dans Project Settings > Database,
#            et s'assurer qu'elle contient ?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/market_place_db

# CORS — "*" (tout) ou origines séparées par des virgules (https://app.example.com,https://...)
CORS_ORIGINS=*

# Stockage des fichiers : "local" (disque, dev) ou "supabase" (persistant, prod)
STORAGE_BACKEND=local
# Requis uniquement si STORAGE_BACKEND=supabase :
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_BUCKET=MarketPace

# JWT (obligatoire) — generer une cle aleatoire d'au moins 32 caracteres
# Astuce: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP (optionnel — utiliser un mot de passe d'application Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=MarketPlace B2B <your-email@gmail.com>

# Logging
LOG_LEVEL=INFO
